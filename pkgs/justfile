# Rust workspace tasks — dev-core / dev-cli / dev-tui / dev-zellij.
#
# The toolchain (cargo, cmake, libiconv, …) lives in the flake's `rust`
# devShell, NOT on your PATH. Run these from a bare shell like:
#
#     nix develop .#rust -c just -f pkgs/justfile ci      # from the repo root
#     nix develop ..#rust -c just ci                      # from inside pkgs/
#
# or drop into the shell once (`nix develop .#rust`) and then just `just ci`.
#
# dev-zellij is a WASM plugin built by nix (see coder.nix `devZellij`), so it
# cannot link for the host: `build`/`test` exclude it, while `check`/`clippy`
# still cover it (neither links).

_default:
    @just --list --justfile {{ justfile() }}

# Fast, full type-check of all four crates (no linking; covers dev-zellij).
check:
    cargo check --workspace

# Build the host binaries (dev-core / dev-cli / dev-tui).
build:
    cargo build --workspace --exclude dev-zellij

# Run all tests (host crates).
test:
    cargo test --workspace --exclude dev-zellij

# The gate a coding agent / CI should run after changes: must-pass correctness.
ci: check test

# Lint (advisory — warnings do not fail). Add `-- -D warnings` to make them fail.
clippy:
    cargo clippy --workspace

# Format every crate in place.
fmt:
    cargo fmt --all

# Report formatting drift without writing (advisory; the tree has some debt).
fmt-check:
    cargo fmt --all --check

# Run the CLI to check real behavior, e.g. `just run-cli task list`.
run-cli *args:
    cargo run --quiet -p dev-cli -- {{ args }}
